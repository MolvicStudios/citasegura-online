/*
  # Permite scripts de la red publicitaria Adsterra (dominios rotativos *.profitablecpmratenetwork.com)
  # y scripts propios necesarios para SvelteKit.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' *.profitablecpmratenetwork.com; style-src 'self' 'unsafe-inline'; img-src * data: blob:; connect-src * data:; frame-src *; object-src 'none'; base-uri 'self'
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
